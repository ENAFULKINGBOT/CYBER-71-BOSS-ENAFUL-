def check_server(host, port=80):
    try:
        socket.setdefaulttimeout(2)
        with socket.socket(socket.AF_INET, socket.SOCK_STREAM) as s:
            s.connect((host, port))
        return "ONLINE 🟢"
    except:
        return "OFFLINE 🔴"

