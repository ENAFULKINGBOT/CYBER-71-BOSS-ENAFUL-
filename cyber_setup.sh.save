#!/bin/bash

# স্ক্রিন ক্লিয়ার করা
clear

# ==========================================================
# ১. ইনস্ট্যান্ট ভয়েস কমান্ড (রান করার সাথে সাথেই বলবে)
# ==========================================================
# টুল লোড হওয়ার আগেই এটি কথা বলে উঠবে
termux-tts-speak "Welcome Boss ENAful. Initializing Cyber 71 system. No password required. Please wait." &

# প্রয়োজনীয় প্রাথমিক টুলস ইনস্টল ও চেক (ব্যানার, ভয়েস ও নেটওয়ার্কের জন্য)
echo -e "\e[1;32m[*] CYBER 71 BOSS ENAFUL সিস্টেম লোড হচ্ছে...\e[0m"
pkg install figlet toilet ruby termux-api dnsutils -y > /dev/null 2>&1
gem install lolcat > /dev/null 2>&1

clear

# ==========================================================
# ২. প্রিমিয়াম ব্যানার ও স্টাইলিশ লুক
# ==========================================================
echo "==========================================================" | lolcat
echo "      :::::::::: ::::    :::     :::     :::::::::: :::   " | lolcat
echo "     :+:        :+:+:   :+:   :+: :+:   :+:        :+:    " | lolcat
echo "    +:+        :+:+:+  +:+  +:+   +:+  +:+        +:+     " | lolcat
echo "   +#++:++#   +#+ +:+ +#+ +#++:++#++: +#++:++#   +#+      " | lolcat
echo "  +#+        +#+  +#+#+# +#+     +#+ +#+        +#+       " | lolcat
echo " #+#        #+#   #+#+# #+#     #+# #+#        #+#        " | lolcat
echo "########## ###    #### ###     ### ###        ##########  " | lolcat
echo "==========================================================" | lolcat
figlet -f slant " CYBER 71" | lolcat
figlet -f small "  BOSS ENAFUL" | lolcat
echo "==========================================================" | lolcat
echo "      🛡️  WELCOME TO CYBER 71 BOSS ENAFUL TOOLS 🛡️          " | lolcat
echo "==========================================================" | lolcat

# ৩. অ্যাডভান্সড সিস্টেম ইনফো (ডিভাইস স্ট্যাটাস)
echo -e "\e[1;34m[!] আপনার ডিভাইসের তথ্য চেক করা হচ্ছে...\e[0m"
sleep 1
echo -e "\e[1;33mডিভাইস মডেল  :\e[0m $(getprop ro.product.model)" | lolcat
echo -e "\e[1;33mঅ্যান্ড্রয়েড ভার্সন:\e[0m $(getprop ro.build.version.release)" | lolcat
echo -e "\e[1;33mলোকাল আইপি   :\e[0m $(ifconfig wlan0 2>/dev/null | grep 'inet ' | awk '{print $2}')" | lolcat
echo -e "\e[1;33mফ্রি র‍্যাম     :\e[0m $(free -m | awk '/Mem:/ { print $4 }') MB" | lolcat
echo "----------------------------------------------------------" | lolcat

# ==========================================================
# ৪. মেইন আপডেট ও প্যাকেজ ইনস্টলেশন প্রসেস
# ==========================================================

echo "[+] টারমাক্স রিপোজিটরি আপডেট এবং আপগ্রেড হচ্ছে..." | lolcat
pkg update -y && pkg upgrade -y

echo "[+] প্রয়োজনীয় সকল হ্যাকিং ও ডেভেলপমেন্ট টুলস ইনস্টল হচ্ছে..." | lolcat
# সকল প্যাকেজ একসাথে (Python, Git, Nmap, Metasploit, etc.)
pkg install python python2 php git nano proot wget curl ruby zip unzip toilet figlet nmap hydra openssh sqlmap termux-api -y

echo "[+] স্টোরেজ পারমিশন চেক করা হচ্ছে..." | lolcat
termux-setup-storage

echo "[+] অপ্রয়োজনীয় ক্যাশ ফাইল পরিষ্কার করা হচ্ছে..." | lolcat
apt autoremove -y && apt autoclean -y

# ৫. অটো শর্টকাট তৈরি (যাতে শুধু 'cyber' লিখলেই টুলটি চলে)
if ! grep -q "alias cyber" ~/.bashrc; then
    echo "alias cyber='bash ~/cyber_setup.sh'" >> ~/.bashrc
    source ~/.bashrc
fi

echo ""
echo "----------------------------------------------------------" | lolcat
figlet -f small "SUCCESS" | lolcat
termux-toast "Setup Completed by BOSS ENAFUL"

# ৬. কাজ শেষ হওয়ার পর ফাইনাল অভিনন্দন ভয়েস
termux-tts-speak "Congratulations Boss ENAful. Your system is now optimized, secured and ready for use."

echo " [✔] অভিনন্দন! আপনার সিস্টেম এখন পুরোপুরি রেডি। " | lolcat
echo " [!] এখন থেকে কোনো পাসওয়ার্ড ছাড়াই 'cyber' লিখলে এটি চলবে।" | lolcat
echo "      Created by: CYBER 71 BOSS ENAFUL " | lolcat
echo "----------------------------------------------------------" | lolcat

# একটি সাকসেস বিপ সাউন্ড
echo -e "\a"

