    markup.add(owner_btn)

    welcome_text = (
        "👋 **Welcome to Cyber.71.ENAFUL Bot**\n\n"
        "🛠 **Status:** Active\n"
        f"👑 **Owner:** Boss Enaful\n"
        f"🆔 **Username:** @{ADMIN_USERNAME}\n\n"
        "নিচের বাটনে ক্লিক করে সরাসরি যোগাযোগ করতে পারেন।"
    )
    bot.send_message(message.chat.id, welcome_text, reply_markup=markup, parse_mode="Markdown")

@bot.message_handler(commands=['gen'])
def generate_link(message):
    if message.chat.id == ADMIN_ID:
        bot.reply_to(message, f"🔗 Your Protected Link: `{SERVER_URL}/track`", parse_mode="Markdown")
    else:
        bot.reply_to(message, "Access Denied!")

def run_flask():
    app.run(host='0.0.0.0', port=5000, use_reloader=False)

if __name__ == '__main__':
    threading.Thread(target=run_flask).start()
    print("সার্ভার এবং পাসওয়ার্ড প্রোটেকশন চালু হয়েছে...")
    bot.infinity_polling()

