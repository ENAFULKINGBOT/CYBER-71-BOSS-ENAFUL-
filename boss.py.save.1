# --- ৪. বায়োমেট্রিক ও ড্যাশবোর্ড (With Delete/Purge) ---
@app.route('/vault')
def vault():
    if not session.get('logged_in'): return redirect(url_for('index'))
    files = os.listdir(UPLOAD_FOLDER)
    status = check_server("google.com")
    html = f"""
    <body style='background:#050505; color:#0f0; font-family:monospace; padding:20px;'>
        <h2 style="color:cyan;">🛡️ BOSS ENAFUL SECURE VAULT</h2>
        <p>📡 Server Status: {status} | Files: {len(files)}</p>
        <hr color='#222'>
    """
    for f in files:
        html += f"""
        <div style="margin:15px 0; border-bottom:1px solid #111; padding-bottom:8px; display:flex; justify-content:space-between;">
            <span style="color:cyan;">📁 {f}</span>
            <div>
                <a href="/download/{f}" style="color:#0f0; text-decoration:none; margin-right:15px;">[ DOWNLOAD ]</a>
                <a href="/delete/{f}" style="color:red; text-decoration:none;">[ DELETE ]</a>
            </div>
        </div>"""
    html += "<br><a href='/logout' style='color:red;'>[ SHUTDOWN ]</a></body>"
    return render_template_string(html)

@app.route('/delete/<n>')
def delete(n):
    if not session.get('logged_in'): return "Access Denied", 403
    try: os.remove(os.path.join(UPLOAD_FOLDER, n))
    except: pass
    return redirect(url_for('vault'))

