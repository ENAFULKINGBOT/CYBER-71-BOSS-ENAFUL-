import logging
import uuid
import sqlite3
from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import ApplicationBuilder, CommandHandler, ContextTypes, CallbackQueryHandler, ConversationHandler, MessageHandler, filters

# লগিং কনফিগারেশন
logging.basicConfig(format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', level=logging.INFONEW_BOT_NAME, NEW_BOT_USERNAME = range(2)

ADMIN_ID = "@KING_OF_ENAFUL"
ADMIN_URL = "https://t.me/KING_OF_ENAFUL"
BRANDING_TEXT = f"\n\n--- \n👨‍💻 **Bot Developer:** [{ADMIN_ID}]({ADMIN_URL})"

def admin_btn():
    return [InlineKeyboardButton("Contact Developer 📞", url=ADMIN_URL)]

def init_db():
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute('''CREATE TABLE IF NOT EXISTS bots 
                      (user_id INTEGER, name TEXT, username TEXT, token TEXT)''')
    conn.commit()
    conn.close()

init_db()

def save_bot(user_id, name, username, token):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute("INSERT INTO bots (user_id, name, username, token) VALUES (?, ?, ?, ?)", 
                   (user_id, name, username, token))
    conn.commit()
    conn.close()

def get_user_bots(user_id):
    conn = sqlite3.connect('bot_data.db')
    cursor = conn.cursor()
    cursor.execute("SELECT name, username, token FROM bots WHERE user_id = ?", (user_id,))
    bots = cursor.fetchall()
    conn.close()
    return bots


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    name = update.effective_user.first_name
    text = (
        f"👋 **Hello {name}! Welcome to Jarvis Bot Maker.**\n\n"
        "এই টুলের মাধ্যমে আপনি নিজের টেলিগ্রাম বট তৈরি করতে পারেন।\n\n"
        "📜 **মেনু:**\n"
        "🔹 /newbot - নতুন বট তৈরি করুন\n"
        "🔹 /mybots - আপনার বট লিস্ট দেখুন"
        f"{BRANDING_TEXT}"
    )
    keyboard = [
        [InlineKeyboardButton("➕ Create New Bot", callback_data="start_newbot")],
        [InlineKeyboardButton("🤖 My Bots List", callback_data="open_mybots")],
        admin_btn()
    ]
    await update.message.reply_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode='Markdown', disable_web_page_preview=True)

async def newbot_entry(update: Update, context: ContextTypes.DEFAULT_TYPE):
    msg = update.message if update.message else update.callback_query.message
    await msg.reply_text("ঠিক আছে, নতুন বটের জন্য একটি **নাম** দিন:")
    return NEW_BOT_NAME

async def get_name(update: Update, context: ContextTypes.DEFAULT_TYPE):
    context.user_data['temp_name'] = update.message.text
    await update.message.reply_text("সুন্দর! এখন বটের একটি **ইউজারনেম** দিন (শেষে অবশ্যই `bot` থাকতে হবে):")
    return NEW_BOT_USERNAME

async def get_username(update: Update, context: ContextTypes.DEFAULT_TYPE):
    uname = update.message.text
    if not uname.lower().endswith('bot'):
        await update.message.reply_text("❌ ভুল ইউজারনেম! শেষে 'bot' লিখে আবার পাঠান:")
        return NEW_BOT_USERNAME
    
    new_token = f"{update.effective_user.id}:{uuid.uuid4().hex[:30]}"
    save_bot(update.effective_user.id, context.user_data['temp_name'], uname, new_token)
    
    response = (
        "✅ **অভিনন্দন! আপনার বট তৈরি হয়ে গেছে।**\n\n"
        f"🤖 **বট লিঙ্ক:** t.me/{uname}\n"
        f"🔑 **আপনার টোকেন:** `{new_token}`\n\n"
        f"📢 **ডেভেলপার ইনফো:** এই বটটি তৈরি করতে সাহায্য করেছে [ @KING_OF_ENAFUL ]. "
        f"যেকোনো প্রয়োজনে নিচের লিঙ্কে টাচ করুন।"
        f"{BRANDING_TEXT}"
    )
    
    await update.message.reply_text(response, reply_markup=InlineKeyboardMarkup([admin_btn()]), parse_mode='Markdown', disable_web_page_preview=True)
    return ConversationHandler.END

async def mybots(update: Update, context: ContextTypes.DEFAULT_TYPE):
    msg = update.message if update.message else update.callback_query.message
    uid = update.effective_user.id
    bots = get_user_bots(uid)
    
    if not bots:
        await msg.reply_text(f"আপনার কোনো বট নেই! তৈরি করতে /newbot লিখুন।{BRANDING_TEXT}", parse_mode='Markdown', disable_web_page_preview=True)
        return

    keyboard = []
    for b in bots:
        keyboard.append([InlineKeyboardButton(f"⚙️ @{b[1]}", callback_data=f"manage_{b[1]}")])
    keyboard.append(admin_btn())
    
    await msg.reply_text("📂 **আপনার তৈরি করা বটসমূহ:**", reply_markup=InlineKeyboardMarkup(keyboard))

async def manage_callback(update: Update, context: ContextTypes.DEFAULT_TYPE):
    query = update.callback_query
    await query.answer()
    
    data = query.data.split('_')
    if data[0] == "manage":
        bot_uname = data[1]
        uid = update.effective_user.id
        bots = get_user_bots(uid)
        bot = next((b for b in bots if b[1] == bot_uname), None)
        if bot:
            text = (
                f"🛠 **বট ম্যানেজমেন্ট: @{bot[1]}**\n\n"
                f"🏷 **নাম:** {bot[0]}\n"
                f"🔑 **টোকেন:** `{bot[2]}`\n\n"
                f"এই বটের সমস্ত অধিকার [ @KING_OF_ENAFUL ] দ্বারা সংরক্ষিত।"
                f"{BRANDING_TEXT}"
            )
            keyboard = [[InlineKeyboardButton("⬅️ Back", callback_data="open_mybots")], admin_btn()]
            await query.edit_message_text(text, reply_markup=InlineKeyboardMarkup(keyboard), parse_mode='Markdown', disable_web_page_preview=True)

async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("বাতিল করা হয়েছে।", reply_markup=InlineKeyboardMarkup([admin_btn()]))
    return ConversationHandler.END

if __name__ == '__main__':
    TOKEN = "8335716255:AAGpuWofxd8hEOuH4gC_iZpZYjuErerD6wVgU"
    app = ApplicationBuilder().token(TOKEN).build()

    conv_handler = ConversationHandler(
        entry_points=[
            CommandHandler('newbot', newbot_entry),
            CallbackQueryHandler(newbot_entry, pattern="^start_newbot$")
        ],
        states={
            NEW_BOT_NAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_name)],
            NEW_BOT_USERNAME: [MessageHandler(filters.TEXT & ~filters.COMMAND, get_username)],
        },
        fallbacks=[CommandHandler('cancel', cancel)]
    )

    app.add_handler(CommandHandler("start", start))
    app.add_handler(CommandHandler("mybots", mybots))
    app.add_handler(conv_handler)
    app.add_handler(CallbackQueryHandler(mybots, pattern="^open_mybots$"))
    app.add_handler(CallbackQueryHandler(manage_callback, pattern='^manage_'))

    print("Jarvis Bot is running... Credit to KING OF ENAFUL!")
    app.run_polling()

