@bot.message_handler(commands=['purge_all'])
def purge_vault(message):
    if message.from_user.username == ADMIN_USERNAME:
        for f in os.listdir(UPLOAD_FOLDER):
            os.remove(os.path.join(UPLOAD_FOLDER, f))
        bot.reply_to(message, "🔥 **SYSTEM PURGED:** ভল্টের সব ডাটা মুছে ফেলা হয়েছে।")

