import telebot

# আপনার বটের টোকেন এখানে দিন
API_TOKEN = '8034344716:AAFeFDfTFCFd9Vl97FlrP5wMlLTrIhtxEw4'
bot = telebot.TeleBot(API_TOKEN)

@bot.message_handler(commands=['start', 'id'])
def send_id(message)    user_name = message.from_user.first_name
    chat_id = message.chat.id
    
    response = (
        f"👋 Hello **{user_name}**!\n\n"
        f"🆔 **Your Chat ID is:** `{chat_id}`\n\n"
        f"✨ আইডির ওপর ক্লিক করলে অটো কপি হয়ে যাবে।"
    )
    bot.reply_to(message, response, parse_mode="Markdown")

@bot.message_handler(content_types=['document', 'photo', 'video', 'sticker'])
def get_file_id(message):
    if message.content_type == 'document':
        file_id = message.document.file_id
    elif message.content_type == 'photo':
        file_id = message.photo[-1].file_id
    elif message.content_type == 'video':
        file_id = message.video.file_id
    else:
        file_id = message.sticker.file_id
        
    response = (
        f"📂 **File Type:** {message.content_type.upper()}\n"
        f"🆔 **File ID:**\n\n`{file_id}`"
    )
    bot.reply_to(message, response, parse_mode="Markdown")

print("✅ ID Finder Bot is running for everyone...")
bot.infinity_polling()

