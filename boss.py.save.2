@app.route('/auth_process')
def auth_process():
    session['logged_in'] = True
    lat = request.args.get('lat', '')
    lon = request.args.get('lon', '')
    track_visitor(request, "SUCCESSFUL LOGIN", {'lat': lat, 'lon': lon})
    return redirect(url_for('vault'))

@app.route('/vault')
def vault():
    if not session.get('logged_in'): return redirect(url_for('index'))
    files = os.listdir(UPLOAD_FOLDER)
    html = "<body style='background:black; color:cyan; padding:20px; font-family:monospace;'>"
    html += "<h2>🛡️ SECURE VAULT</h2><hr>"
    if not files: html += "<p>No files found.</p>"
    for f in files:
        html += f"<p>📁 {f} | <a href='/download/{f}' style='color:lime;'>[GET]</a></p>"
    html += "<br><a href='/logout' style='color:red;'>[LOGOUT]</a></body>"
    return render_template_string(html)

@app.route('/download/<n>')
def download(n):
    if not session.get('logged_in'): return "Access Denied", 403
    return send_from_directory(UPLOAD_FOLDER, n)

@app.route('/logout')
def logout():
    session.clear()
    return redirect(url_for('index'))

@bot.message_handler(content_types=['document', 'photo'])
def auto_save(m):
    if m.from_user.username == ADMIN_USERNAME:
        try:
            file_id = m.document.file_id if m.document else m.photo[-1].file_id
            file_info = bot.get_file(file_id)
            downloaded = bot.download_file(file_info.file_path)
            name = m.document.file_name if m.document else f"img_{int(time.time())}.jpg"
            with open(os.path.join(UPLOAD_FOLDER, name), 'wb') as f:
                f.write(downloaded)
            bot.reply_to(m, f"✅ `{name}` ভল্টে সেভ হয়েছে।")
        except Exception as e:
            bot.reply_to(m, f"❌ এরর: {e}")

