import telebot
from telebot import types # বাটন তৈরির জন্য
import requests
from flask import Flask, request
import threading
import geocoder
from datetime import datetime

# --- ১. কনফিগারেশন ---
API_TOKEN = '8756220877:AAGKKlYU8MDptXx2b5-EvCG_hwgRREhDfQk' 
ADMIN_USERNAME = 'KING_OF_ENAFUL'
ADMIN_ID = None

bot = telebot.TeleBot(API_TOKEN)
app = Flask(__name__)
SERVER_URL = "http://localhost:5000" 

# --- ২. হোম পেজ ---
@app.route('/')
