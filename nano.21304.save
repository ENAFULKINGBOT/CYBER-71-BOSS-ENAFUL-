# ফাইল আইডি বের করার ফাংশন
@bot.message_handler(content_types=['document'])
def get_file_id(message):
    bot.reply_to(message, f"✅ আপনার ফাইলের আইডি:\n\n`{message.document.file_id}`", parse_mode="Markdown")

def get_inline_keyboard():
    inline_markup = InlineKeyboardMarkup(row_width=2)
    search_btn = InlineKeyboardButton("🔍 Search Apps", callback_data="search_mode")
    channel_btn = InlineKeyboardButton("📢 Join Channel", url=CHANNEL_LINK)
    inline_markup.add(search_btn, channel_btn)
    
    buttons = [InlineKeyboardButton(text=name, callback_data=data) for name, data in apps_list]
    inline_markup.add(*buttons)
    return inline_markup

@bot.message_handler(commands=['start'])
def send_welcome(message):
    reply_markup = ReplyKeyboardMarkup(resize_keyboard=True)
    reply_markup.row(KeyboardButton("🔍 Search Apps"), KeyboardButton("📱 All Apps"))
    
    welcome_text = (
        "🛡️ **WELCOME TO CYBER 69 ENAFUL** 🛡️\n"
        "━━━━━━━━━━━━━━━━━━━━━━━━\n"
        "🔥 **SYSTEM Status:** ONLINE ✅\n"
        "👤 **Owner:** BOSS ENAFUL\n\n"
        "অ্যাপ সরাসরি ডাউনলোড করতে নিচের বাটন ব্যবহার করুন।"
    )
    bot.send_message(message.chat.id, welcome_text, reply_markup=reply_markup, parse_mode="Markdown")
    bot.send_message(message.chat.id, "--- 69 Apps List ---", reply_markup=get_inline_keyboard())

@bot.callback_query_handler(func=lambda call: call.data.startswith('app_'))
def handle_app_click(call):
    app_key = call.data
    app_name = next((name for name, data in apps_list if data == app_key), "App")
    
    if app_key in file_ids and "আইডি_এখানে_বসান" not in file_ids[app_key]:
        bot.answer_callback_query(call.id, f"{app_name} পাঠানো হচ্ছে...")
        bot.send_document(call.message.chat.id, file_ids[app_key], caption=f"📦 **{app_name}**\n👤 Sent by: **BOSS ENAFUL**")
    else:
        bot.answer_callback_query(call.id, "❌ এই ফাইলটি এখনো আপলোড করা হয়নি!", show_alert=True)

@bot.message_handler(func=lambda message: message.text == "📱 All Apps")
def show_all(message):
    bot.send_message(message.chat.id, "--- 69 Apps List ---", reply_markup=get_inline_keyboard())

@bot.callback_query_handler(func=lambda call: call.data == "search_mode")
@bot.message_handler(func=lambda message: message.text == "🔍 Search Apps")
def start_search(msg_or_call):
    chat_id = msg_or_call.chat.id if hasattr(msg_or_call, 'chat') else msg_or_call.message.chat.id
    msg = bot.send_message(chat_id, "⌨️ আপনি যে অ্যাপটি খুঁজছেন তার নাম লিখুন:")
    bot.register_next_step_handler(msg, process_search)

def process_search(message):
    query = message.text.lower()
    results = [InlineKeyboardButton(text=name, callback_data=data) for name, data in apps_list if query in name.lower()]
    if results:
        markup = InlineKeyboardMarkup(row_width=1)
        markup.add(*results)
        bot.send_message(message.chat.id, "✅ আপনার অ্যাপগুলো নিচে দেওয়া হলো:", reply_markup=markup)
    else:
        bot.send_message(message.chat.id, "❌ দুঃখিত! এই নামে কোনো অ্যাপ পাওয়া যায়নি।", reply_markup=get_inline_keyboard())

print("✅ CYBER 69 ENAFUL Bot is online...")
bot.infinity_polling()
